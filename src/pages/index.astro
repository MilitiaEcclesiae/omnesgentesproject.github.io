---
import Layout from '~/layouts/PageLayout.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import EventGallery from '~/components/widgets/EventGallery.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Omnes Gentes Project',
  ignoreTitleTemplate: true,
};

---

<Layout metadata={metadata}>
  <EventGallery />
  <BlogLatestPosts
    title="Las Ultimas Misiones"
    information={``}
  />

  <Testimonials
    title="Testimonios"
    testimonials={[
      {
        testimonial: `Participar en la misión de evangelización en Malawi nos transformó profundamente, llevándonos a vivir una experiencia de fe y humildad, donde compartimos la alegría del Evangelio y fuimos testigos de conversiones y bautismos en aldeas que nunca habían oído hablar de Jesús.`,
        name: 'Lan y Serge',
        image: {
          src: '~/assets/images/testimonio_malawei.jpeg',
          alt: 'Emily Kennedy Image',
        },
      },
      {
        testimonial: `Después de una juventud de excesos, mi conversión me llevó a fundar Dominus Estudios, una productora católica que busca evangelizar a través de la belleza y la creatividad, llevando el mensaje de Cristo a lugares inesperados y cambiando vidas con cada proyecto.`,
        name: 'Luis María Piccinali',
        image: {
          src: '~/assets/images/02.jpg',
          alt: 'Luis María Piccinali',
        },
      },
      {
        testimonial: `Truth sets you free`,
        name: 'Xavi Z. Wong',
        image: {
          src: '~/assets/images/testimonio_xzw.png',
          alt: 'X.Z.W.',
        },
      },
    ]}
    callToAction={{
      target: '_blank',
      text: 'More testimonials...',
      href: getPermalink('testimonios', 'category'),
      icon: 'tabler:chevron-right',
    }}
  />
  
<Hero2
    title="¡ÚNETE A NUESTRA MISIÓN Y CAMBIA VIDAS!"
    subtitle="Haz tu donación hoy y sé un instrumento de salvación.<br>Juntos, con los cinco panes y dos peces que nos da Dios, podemos seguir evangelizando y llevando la luz de Cristo a los lugares más necesitados.<br><b>¡Viva Cristo Rey!"
    actions={[
      { variant: 'primary', 
        text: 'Donacion', 
        href: 'https://donorbox.org/omnesgentesproject', //getPermalink('/Donation'),
        icon: 'tabler:heart'},
    ]}
    image={{
      src: '~/assets/images/IMG_1380.jpeg',
      alt: 'Donation',
    }}
  />
</Layout>

