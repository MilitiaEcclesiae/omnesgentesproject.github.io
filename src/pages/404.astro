---
import Layout from '~/layouts/Layout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const title = `Error 404`;
---

<!-- use image of francis xavier as 404 -->

<Layout metadata={{ title }}>
  <section 
      class="flex items-center h-full p-16"
      style="background-image: url('src/assets/images/404page.jpeg');"
      >
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">Error</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">Oops! This page seems to have wandered off the path.</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">
          But don’t fret! There’s a whole world of wisdom and adventure waiting for you on our homepage—go forth and explore!
        </p>
        <a rel="noopener noreferrer" href={getHomePermalink()} class="btn ml-4">Back to homepage</a>
        <br/><br/><br/>
      </div>

      <img src="/src/assets/images/404page.jpeg" class="w-100 h-100 object-cover mb-8 " />

    </div>
  </section>
</Layout>
