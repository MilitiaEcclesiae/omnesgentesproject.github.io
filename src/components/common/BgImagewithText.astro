---
const { backgroundImage, bgSize = 'cover', bgOpacity = 1, title, description1, description2 } = Astro.props;
---

<section
  class="relative w-full h-[400px]"
  style={`background-image: url(${backgroundImage}); background-size: ${bgSize}; background-position: center; background-attachment: fixed; opacity: ${bgOpacity};`}
>
  <!-- Background overlay -->
  <div class="absolute inset-0 bg-black opacity-40"></div>

  <!-- Content -->
  <div class="relative z-10 flex justify-center items-center w-full h-full text-center text-white px-4">
    <div class="max-w-4xl px-4 md:px-8 prose prose-lg">
      <h2 class="text-7xl font-semibold text-white-500 mb-2">
        {title}
      </h2>

      <p1>
        {description1} <span class="text-grey-500 font-semibold"></span><br>
        {description2} <span class="text-grey-500"></span>
      </p1>
      <p5 class="text-1x1 text-white-500 mb-2">
        {description2} 
      </p5>
    </div>
  </div>
</section>
