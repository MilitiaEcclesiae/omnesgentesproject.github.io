---
const { backgroundImage, bgSize = 'cover', bgOpacity = 1, title, description,description1 } = Astro.props;
---

<section
  class="relative w-full h-[350px]"
  style={`background-image: url(${backgroundImage}); background-size: ${bgSize}; background-position: center; background-attachment: scroll; opacity: ${bgOpacity};`}
>
  <!-- Background overlay -->
  <div class="absolute inset-0 opacity-7"></div>

  <!-- Content -->
  <div class="relative z-10 flex justify-center items-center w-full h-full text-center text-red px-4">
    <div class="max-w-4xl px-4 md:px-8 prose prose-lg">
      <h2 class="text-7xl font-bold text-blue-300 mb-2">
        {title}
      </h2>
    </div>
    <div class="absolute bottom-0 right-0 p-4 text-right">
      <p class="text-2xl font-semibold text-blue-300 mb-2">
        {description}<br>
        {description1}
      </p>
    </div>
  </div>
</section>
